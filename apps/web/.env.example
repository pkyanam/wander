# ─────────────────────────────────────────────────────────────────────────────
# Wander — LOCAL development environment
# Copy this file to `.env.local` (same folder) and fill in the values.
# `.env.local` is gitignored. Next.js loads it automatically; the db tooling
# (drizzle-kit, migrate, seed) loads it too.
# ─────────────────────────────────────────────────────────────────────────────

# --- Clerk (auth) ---
# Create an application at https://dashboard.clerk.com, then copy the keys from
# the "API Keys" page. The test (pk_test_/sk_test_) keys work on localhost.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- Admin access ---
# The public app is anonymous; only /admin requires signing in. Grant admin to
# specific accounts with a comma-separated email allowlist, e.g.
#   ADMIN_EMAILS=you@example.com,teammate@example.com
# If left empty, the FIRST account to sign in is auto-promoted to admin
# (zero-config bootstrap). You can also set publicMetadata.role="admin" in Clerk.
ADMIN_EMAILS=

# --- Database ---
# Points at the Postgres started by `docker compose up -d postgres`.
DATABASE_URL=postgres://wander:wander@localhost:5432/wander

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Catalog image enrichment (pnpm db:enrich) ---
# Optional. Defaults to Microlink's free tier (no key) when unset.
#   SCREENSHOT_PROVIDER: microlink (default) | template | none
#   MICROLINK_API_KEY:   Microlink Pro key (optional)
#   SCREENSHOT_URL_TEMPLATE: only for provider=template; must contain {url}
SCREENSHOT_PROVIDER=microlink
MICROLINK_API_KEY=
SCREENSHOT_URL_TEMPLATE=

# --- Curation Engine (pnpm curate) ---
# All optional. The engine runs without any of these (adapters needing a key
# are skipped with a log line); `pnpm curate --mock` needs none of them.
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
BROWSERBASE_MAX_CONCURRENCY=20
EXA_API_KEY=
# Small/fast model id + key for an OpenAI-compatible chat-completions endpoint.
# Absent → deterministic heuristic enrichment (no external call).
CURATION_MODEL=
CURATION_MODEL_API_KEY=
# Override for non-OpenAI gateways (default https://api.openai.com/v1). Posts to
# {BASE_URL}/chat/completions; a trailing slash is fine.
CURATION_MODEL_BASE_URL=
CURATION_PER_DOMAIN_CAP=3
CURATION_FETCH_TIMEOUT_MS=8000
