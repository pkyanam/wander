# ─────────────────────────────────────────────────────────────────────────────
# Wander — deployment env (docker-compose / Coolify)
#
# Local development uses apps/web/.env.local instead (see apps/web/.env.example).
# This file documents the variables docker-compose substitutes at deploy time.
# Copy to `.env` and fill in before running `docker compose up`.
# ─────────────────────────────────────────────────────────────────────────────

# --- App ---
# Public URL the app is served from (used for absolute links, PWA, OAuth callbacks).
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database (Postgres) ---
POSTGRES_USER=wander
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=wander
# The app connects using this URL. Host is the compose service name "postgres".
DATABASE_URL=postgres://wander:change-me-in-production@postgres:5432/wander

# --- Clerk (auth) ---
# Get these from https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- Cloudflared (public ingress) ---
# Token from a Cloudflare Zero Trust Tunnel. The cloudflared service runs by
# default and is the app's public ingress, so this is REQUIRED for a full
# deploy. Route the tunnel's public hostname to the internal service
# http://app:3000 in the Cloudflare Zero Trust dashboard.
CLOUDFLARED_TUNNEL_TOKEN=

# --- Catalog image enrichment (pnpm db:enrich) ---
# How to obtain a hero screenshot when a destination has no OpenGraph image.
#   microlink (default) — https://microlink.io, free tier needs no key
#   template            — provide SCREENSHOT_URL_TEMPLATE below
#   none                — disable the screenshot fallback (og-image only)
SCREENSHOT_PROVIDER=microlink
# Optional Microlink Pro key (uses the pro endpoint when set).
MICROLINK_API_KEY=
# Used only when SCREENSHOT_PROVIDER=template. Must contain {url}; it is replaced
# with the URL-encoded target. Example for ScreenshotOne/urlbox/thum.io etc.
SCREENSHOT_URL_TEMPLATE=

# --- Curation Engine (pnpm curate / the gated `curator` compose service) ---
# All optional: the engine runs without any of these (adapters that need a key
# are skipped with a log line). `pnpm curate --mock` needs none of them.
#
# Browserbase — discovery (Search API) + browser lane (Sessions/Stagehand).
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
# Cap concurrent browser sessions; stay under your Browserbase plan limit.
BROWSERBASE_MAX_CONCURRENCY=20
# Exa — neural search + find_similar (quality expansion from our best sites).
EXA_API_KEY=
# Enrichment model (hook/summary/taxonomy tags). Small/fast model id + key for
# an OpenAI-compatible chat-completions endpoint. Absent → heuristic enrichment.
CURATION_MODEL=
CURATION_MODEL_API_KEY=
# Override for non-OpenAI gateways (defaults to https://api.openai.com/v1). The
# engine posts to {BASE_URL}/chat/completions; a trailing slash is fine.
CURATION_MODEL_BASE_URL=
# Engine tuning.
CURATION_PER_DOMAIN_CAP=3
CURATION_FETCH_TIMEOUT_MS=8000
